TELEGRAM_TOKEN=your_telegram_bot_token
ADMIN_CHAT_ID=your_telegram_chat_id
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_WSS_URL=wss://api.mainnet-beta.solana.com
GOPLUS_API_KEY=your_goplus_api_key
HONEYPOT_API_KEY=your_honeypot_api_key

# Database — leave empty for SQLite, set for PostgreSQL
DATABASE_URL=

# Twitter/X API (optional)
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here

# Helius (optional)
HELIUS_API_KEY=your_helius_api_key_here

# Feature flags
ENABLE_WALLET_ANALYSIS=True
ENABLE_SOCIAL_SIGNALS=True
ENABLE_RUG_DETECTION=True

# Dashboard
ENABLE_DASHBOARD=True
DASHBOARD_PORT=8000
DASHBOARD_API_KEY=change-me
CORS_ORIGINS=["http://localhost:3000"]

# Auto-trading (SAFETY: keep False)
ENABLE_AUTO_BUY=False
ENABLE_AUTO_SELL=False
ENABLE_CIRCUIT_BREAKER=True

# Wallet (NEVER commit real key)
WALLET_PRIVATE_KEY=

# Position sizing
MAX_POSITION_SIZE_SOL=0.2
MIN_POSITION_SIZE_SOL=0.05
MAX_OPEN_POSITIONS=3
MIN_SIGNAL_SCORE_FOR_BUY=0.72
DAILY_LOSS_LIMIT_PERCENT=15.0
